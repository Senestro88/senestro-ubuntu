#!/data/data/com.termux/files/usr/bin/bash
# =============================================================================
# senestro-ubuntu/distro/x11stop-senestro-ubuntu
# Stops the XFCE4 session and Termux-X11 server cleanly.
# Run this in TERMUX (not inside Ubuntu).
# =============================================================================

echo "Stopping Senestro Ubuntu Desktop..."
pkill -f "com.termux.x11" 2>/dev/null
pkill -f "pulseaudio"     2>/dev/null
pkill -f "xfce4-session"  2>/dev/null
pkill -f "xfwm4"          2>/dev/null
pkill -f "xfce4-panel"    2>/dev/null
pkill -f "qdbus"          2>/dev/null
echo "Desktop stopped."
