#!/data/data/com.termux/files/usr/bin/bash
# =============================================================================
# senestro-ubuntu/distro/x11start-senestro-ubuntu
# Starts the Ubuntu XFCE4 desktop via Termux-X11.
# Run this in TERMUX (not inside Ubuntu) after `sudo bash gui.sh` completes.
# Open the Termux-X11 app first, then run this script.
#
# Requirements (Termux side):
#   pkg install x11-repo
#   pkg install termux-x11-nightly pulseaudio qt5-qttools
# Requirements (Ubuntu side):
#   xorg-xserver-xephyr  (installed by gui.sh)
# =============================================================================

DISPLAY_NUM=0

echo ""
echo "Starting Senestro Ubuntu Desktop (Ubuntu + XFCE4)..."
echo ""

# ── Clean up stale sessions ────────────────────────────────────────────────
echo "Cleaning up old sessions..."
pkill -f "com.termux.x11" 2>/dev/null
pkill -f "xfce4-session"  2>/dev/null
pkill -f "xfwm4"          2>/dev/null
pkill -f "xfce4-panel"    2>/dev/null
pkill -f "qdbus"          2>/dev/null
pkill -f "pulseaudio"     2>/dev/null
sleep 2

# Remove stale X lock/socket files — termux-x11 does not clean these on exit
rm -f /tmp/.X${DISPLAY_NUM}-lock
rm -f /tmp/.X11-unix/X${DISPLAY_NUM}
rmdir /tmp/.X11-unix 2>/dev/null

# ── Fix D-Bus machine-id BEFORE entering proot ────────────────────────────
ROOTFS_MACHINEID="$(proot-distro login ubuntu -- cat /etc/machine-id 2>/dev/null)"
if [ -z "$ROOTFS_MACHINEID" ] || [ ${#ROOTFS_MACHINEID} -ne 32 ]; then
    echo "Generating D-Bus machine-id..."
    NEW_UUID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null | tr -d '-')"
    [ -z "$NEW_UUID" ] && NEW_UUID="$(dd if=/dev/urandom bs=16 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n')"
    proot-distro login ubuntu -- bash -c \
        "echo '$NEW_UUID' > /etc/machine-id
         mkdir -p /var/lib/dbus
         echo '$NEW_UUID' > /var/lib/dbus/machine-id"
fi

# ── PulseAudio ────────────────────────────────────────────────────────────
echo "Starting PulseAudio..."
pulseaudio --start --exit-idle-time=-1
sleep 1
pactl load-module module-native-protocol-tcp \
    auth-ip-acl=127.0.0.1 auth-anonymous=1 2>/dev/null

# ── Termux-X11 presence check ─────────────────────────────────────────────
if ! command -v termux-x11 &>/dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  ERROR: termux-x11 is not installed."
    echo ""
    echo "  Fix — run these in Termux:"
    echo "    pkg install x11-repo"
    echo "    pkg install termux-x11-nightly"
    echo ""
    echo "  Then open the Termux-X11 companion app at least once"
    echo "  before running this script again."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 1
fi

# ── XFCE4 preflight check (inside Ubuntu) ─────────────────────────────────
if ! proot-distro login ubuntu --command -v startxfce4 &>/dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  ERROR: XFCE4 is not installed inside Ubuntu."
    echo ""
    echo "  Fix — run these commands:"
    echo "    senestro-ubuntu"
    echo "    sudo bash gui.sh"
    echo ""
    echo "  Then try x11start-senestro-ubuntu again."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 1
fi

# ── Termux-X11 ────────────────────────────────────────────────────────────
echo "Starting X11 on :${DISPLAY_NUM} ..."
termux-x11 :${DISPLAY_NUM} -ac &
sleep 3

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Switch to Termux-X11 app to see the desktop!"
echo "  Display : :${DISPLAY_NUM}"
echo "  Audio   : PulseAudio (127.0.0.1)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Launch XFCE4 inside Ubuntu ────────────────────────────────────────────
# --shared-tmp is CRITICAL: makes proot share Termux's /tmp so the X11
# socket created by termux-x11 is visible inside the container.
# Without it, XFCE4 cannot find the display and shows "already running".
proot-distro login ubuntu \
    --shared-tmp \
    --fix-low-ports \
    --bind /dev/null:/proc/sys/kernel/cap_last_last \
    -- env \
    DISPLAY=:${DISPLAY_NUM} \
    PULSE_SERVER=127.0.0.1 \
    XDG_RUNTIME_DIR=/tmp/runtime-root \
    bash -c \
    "mkdir -p /tmp/runtime-root && \
     chmod 700 /tmp/runtime-root && \
     dbus-launch --exit-with-session startxfce4"
