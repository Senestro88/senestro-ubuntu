#!/usr/bin/env bash
# =============================================================================
# senestro-ubuntu/distro/vncstop
# Kills all running VNC server instances and cleans up lock/socket files.
# FIX: replaced hardcoded '/username/' path with the $HOME variable so it
#      resolves correctly for whichever user runs this script.
# =============================================================================

# Kill all VNC server instances on this machine
vncserver -kill :*

# Remove stale PID files left by previous VNC sessions
rm -rf "$HOME/.vnc/localhost:"*.pid

# Remove the X display lock file for display :1
rm -rf /tmp/.X1-lock

# Remove the X Unix domain socket for display :1
rm -rf /tmp/.X11-unix/X1
